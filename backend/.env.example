# Anthropic API key used server-side only for the AI narrative layer and Credit Copilot.
# Get one at https://console.anthropic.com/
# If left unset, the narrative/copilot endpoints gracefully fall back to
# locally-derived text instead of crashing.
ANTHROPIC_API_KEY=

# "mock" (default) uses the built-in MockAdapter with realistic sample data.
# "live" switches to LiveAdapter (stubbed — see src/adapters/LiveAdapter.ts).
DATA_MODE=mock

# Port the Express API listens on (local only; ignored on Vercel).
PORT=4000

# Base URL of the Python ML risk microservice (XGBoost PD model + SHAP).
# Local default: http://localhost:8000
# On Vercel: set this to your hosted ML URL (Railway/Render/Docker), or leave
# empty — the API degrades gracefully (ml_risk.available=false).
ML_SERVICE_URL=http://localhost:8000
