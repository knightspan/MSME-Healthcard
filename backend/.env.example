# Anthropic API key used server-side only for the AI narrative layer.
# Get one at https://console.anthropic.com/
# If left unset, the narrative endpoint gracefully falls back to a
# locally-derived summary instead of crashing.
ANTHROPIC_API_KEY=

# "mock" (default) uses the built-in MockAdapter with realistic sample data.
# "live" switches to LiveAdapter (stubbed — see src/adapters/LiveAdapter.ts).
DATA_MODE=mock

# Port the Express API listens on.
PORT=4000
