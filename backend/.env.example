# Anthropic API key used server-side only for the AI narrative layer.
# Get one at https://console.anthropic.com/
# If left unset, the narrative endpoint gracefully falls back to a
# locally-derived summary instead of crashing.
ANTHROPIC_API_KEY=

# "mock" (default) uses the built-in MockAdapter with realistic sample data.
# "live" switches to LiveAdapter (stubbed — see src/adapters/LiveAdapter.ts).
DATA_MODE=mock

# Port the Express API listens on.
PORT=4000

# Base URL of the Python ML risk microservice (XGBoost PD model + SHAP).
# See ml-service/README.md to train the model and run this service.
# If unreachable, the pipeline gracefully degrades: ml_risk.available=false
# and the rule-based score/narrative continue to work normally.
ML_SERVICE_URL=http://localhost:8000
